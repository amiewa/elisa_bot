{
  "env": {
    "es2020": true
  },
  "globals": {
    "SpreadsheetApp": "readonly",
    "CacheService": "readonly",
    "PropertiesService": "readonly",
    "LockService": "readonly",
    "UrlFetchApp": "readonly",
    "Utilities": "readonly",
    "MailApp": "readonly",
    "ContentService": "readonly",
    "Logger": "readonly",
    "Session": "readonly",

    "SHEET": "writable",
    "SS": "writable",
    "SCRIPT_START": "writable",

    "getConfig": "readonly",
    "logError": "readonly",
    "incrementCounter": "readonly",
    "loadNGWords": "readonly",
    "containsNGWord": "readonly",
    "isTimeSafe": "readonly",
    "isNightTime": "readonly",
    "createAdapter": "readonly",
    "callMisskeyApi": "readonly",
    "callMastodonApi": "readonly",
    "learn": "readonly",
    "generate": "readonly",
    "NGramStore": "readonly",
    "runDailyMaintenance": "readonly",
    "runFollowSync": "readonly",
    "processMarkovPost": "readonly",
    "processMastodonPolling": "readonly",

    "getSheet_": "readonly",
    "getProp_": "readonly",
    "setProp_": "readonly",
    "deleteProp_": "readonly",
    "clearConfigCache_": "readonly",
    "cleanupOldCounters_": "readonly",
    "now_": "readonly",
    "validateConfigValues": "readonly",

    "buildAuthHeader": "readonly",
    "parseLinkHeader": "readonly",
    "misskeyNoteToUnified": "readonly",
    "mastodonNoteToUnified": "readonly",
    "mastodonNotificationToUnified": "readonly",
    "stripHtml": "readonly",
    "normalizeAcct": "readonly",

    "module": "writable"
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", {
      "varsIgnorePattern": "^(doPost|onOpen|mainDispatcher|setupSpreadsheet|validateConfig|manageApiTokens|cleanupAfterPlatformSwitch|testShowConfig|runFollowSync|executeAutoDelete|runDailyMaintenance|processMarkovPost|processMastodonPolling|SHEET|SS|SCRIPT_START|getConfig|logError|incrementCounter|loadNGWords|containsNGWord|isTimeSafe|isNightTime|createAdapter|callMisskeyApi|callMastodonApi|makeApiError_|createMisskeyAdapter_|createMastodonAdapter_|learn|generate|NGramStore|getSheet_|getProp_|setProp_|deleteProp_|clearConfigCache_|cleanupOldCounters_|now_)"
    }],
    "no-undef": "error",
    "no-redeclare": ["error", { "builtinGlobals": false }],
    "eqeqeq": ["error", "smart"],
    "curly": ["error", "multi-line"],
    "no-eval": "error"
  },
  "overrides": [
    {
      "files": ["src/lib/*.js", "tests/**/*.js"],
      "env": {
        "es2020": true,
        "node": true,
        "jest": true
      },
      "parserOptions": {
        "ecmaVersion": 2020,
        "sourceType": "commonjs"
      },
      "rules": {
        "no-unused-vars": ["warn", {
          "argsIgnorePattern": "^_"
        }]
      }
    }
  ]
}
